# LiveKit server (public — used in browser)
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# LiveKit credentials (server-side only — never expose to client)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# SpatialReal (public — used in browser for avatar SDK initialization)
NEXT_PUBLIC_SPATIALREAL_APP_ID=
NEXT_PUBLIC_SPATIALREAL_AVATAR_ID=

# Avatar feature flag (server-side only).
# Must match ENABLE_AVATAR in agent/.env.
ENABLE_AVATAR=true

# Note: SPATIALREAL_API_KEY is NOT needed on the frontend in RTC mode.
# The Python agent handles SpatialReal auth via livekit-plugins-spatialreal.
